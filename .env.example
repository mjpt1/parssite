# ---------------------------------------------------------------------------
# Database (MySQL — e.g. cPanel MySQL®)
# ---------------------------------------------------------------------------
# Example:
#   mysql://USER:PASSWORD@localhost:3306/dbname
# (URL-encode special characters in the password, e.g. @ -> %40)
DATABASE_URL="mysql://user:password@localhost:3306/parsenergy"

# ---------------------------------------------------------------------------
# Email notifications (optional — the form still works without these,
# leads are always stored in the database and logged to the server console).
#
# Option A) Resend  -> set RESEND_API_KEY
# Option B) SMTP / Nodemailer -> set SMTP_HOST, SMTP_PORT, SMTP_USER, SMTP_PASS
# ---------------------------------------------------------------------------

# Where the lead notification is sent
LEAD_NOTIFICATION_EMAIL="sales@parsenergy.example"
# The "from" address shown on the notification email
EMAIL_FROM="Pars Energy <onboarding@resend.dev>"

# --- Option A: Resend ---
RESEND_API_KEY=""

# --- Option B: SMTP (Nodemailer) ---
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
